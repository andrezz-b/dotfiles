#!/bin/bash

# Mise tools hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "======================================================"
echo "  Installing mise tools"
echo "======================================================"
echo ""

# Add mise to PATH for this session
export PATH="$HOME/.local/bin:$PATH"

# Check if mise is installed
if ! command -v mise &> /dev/null; then
    echo -e "${RED}⨯ mise not found.${NC}"
    if [ "$CHEZMOI_OS" = "darwin" ]; then
        echo "Please install via Homebrew: brew install mise"
    else
        echo "Please install via: curl https://mise.run | sh"
    fi
    exit 1
fi

echo -e "${GREEN}✓ mise is installed${NC}"

# Activate mise for this session
eval "$(mise activate bash)"

# Install mise tools
echo ""
echo "Installing mise tools..."
echo ""

set +e
mise install
install_result=$?
set -e

if [ $install_result -eq 0 ]; then
    echo ""
    echo -e "${GREEN}✓ Mise tools installed successfully!${NC}"
    echo ""
    echo "Installed tools:"
    mise list
else
    echo ""
    echo -e "${YELLOW}⨯ Some mise tools failed to install.${NC}"
    echo ""
    echo "Partially installed tools:"
    mise list
    echo ""
    echo "Troubleshooting:"
    echo "  1. Check mise status: mise doctor"
    echo "  2. Try installing manually: mise install"
    echo "  3. Check network connectivity"
    echo ""

    read -p "Accept partial installation? [y/N]: " accept_partial
    if [[ ! $accept_partial =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

echo ""
echo -e "${GREEN}======================================================"
echo "  Mise Tools Installation Complete!"
echo "======================================================${NC}"
echo ""
