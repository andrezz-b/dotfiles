#!/bin/bash

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "======================================================"
echo "  Configuring Default Shell"
echo "======================================================"
echo ""

if [ "$SHELL" != "$(which zsh)" ]; then
    # Check if zsh is in /etc/shells
    if ! grep -q "$(which zsh)" /etc/shells; then
        echo "$(which zsh)" | sudo tee -a /etc/shells
    fi

    echo "Changing default shell to zsh..."
    if chsh -s "$(which zsh)"; then
        echo -e "${GREEN}✓ Default shell changed to zsh${NC}"
        echo ""
        echo -e "${YELLOW}IMPORTANT: You must log out and log back in for the shell change to take effect.${NC}"
        echo ""
        echo -e "${YELLOW}********************************************************${NC}"
        echo -e "${YELLOW}*  ACTION REQUIRED: LOG OUT AND LOG BACK IN           *${NC}"
        echo -e "${YELLOW}*                                                      *${NC}"
        echo -e "${YELLOW}*  Your default shell has been changed to zsh.        *${NC}"
        echo -e "${YELLOW}*  You must log out and log back in to apply this     *${NC}"
        echo -e "${YELLOW}*  change before continuing with chezmoi.             *${NC}"
        echo -e "${YELLOW}*                                                      *${NC}"
        echo -e "${YELLOW}*  After logging back in, run:                        *${NC}"
        echo -e "${YELLOW}*    chezmoi apply                                    *${NC}"
        echo -e "${YELLOW}********************************************************${NC}"
        echo ""
    else
        echo -e "${RED}⨯ Failed to change shell. You may need to run manually:${NC}"
        echo "  chsh -s \$(which zsh)"
    fi
else
    echo -e "${GREEN}✓ Default shell is already zsh${NC}"
fi

echo ""
