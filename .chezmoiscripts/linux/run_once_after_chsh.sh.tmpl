#!/bin/bash

set -euo pipefail

if [ "$SHELL" != "$(which zsh)" ]; then
    # Check if zsh is in /etc/shells
    if ! grep -q "$(which zsh)" /etc/shells 2>/dev/null; then
        echo "$(which zsh)" | sudo tee -a /etc/shells >/dev/null
    fi

    if chsh -s "$(which zsh)" 2>/dev/null; then
        echo ""
        echo "********************************************************"
        echo "*  ACTION REQUIRED: LOG OUT AND LOG BACK IN           *"
        echo "*                                                      *"
        echo "*  Your default shell has been changed to zsh.        *"
        echo "*  You must log out and log back in to apply this     *"
        echo "*  change before continuing with chezmoi.             *"
        echo "*                                                      *"
        echo "*  After logging back in, run:                        *"
        echo "*    chezmoi apply                                    *"
        echo "********************************************************"
        echo ""
    else
        echo "⨯ Failed to change shell. You may need to run manually:"
        echo "  chsh -s \$(which zsh)"
    fi
fi
