#!/bin/bash

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "======================================================"
echo "  Linux Package Installation"
echo "======================================================"
echo ""

# Update package list
sudo apt-get update

# Install packages
# Core tools
sudo apt-get install -y \
    zsh \
    git \
    curl \
    wget \
    build-essential

# CLI Tools
sudo apt-get install -y \
    bat \
    imagemagick \
    tmux \
    libxcb-xkb1

# Bat executable might be installed with the wrong name
mkdir -p ~/.local/bin
[ -e ~/.local/bin/bat ] || ln -s /usr/bin/batcat ~/.local/bin/bat

# Install zoxide (smarter cd command)
echo "Installing zoxide..."
curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh

# Install mise (runtime version manager)
echo "Installing mise..."
curl https://mise.run | sh

# Install oh-my-posh
echo "Installing oh-my-posh..."
curl -s https://ohmyposh.dev/install.sh | bash -s

# Install fonts
echo "Installing JetBrains Mono font..."
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/JetBrains/JetBrainsMono/master/install_manual.sh)"

echo ""
echo -e "${GREEN}======================================================"
echo "  System Package Installation Complete!"
echo "======================================================${NC}"
echo ""
