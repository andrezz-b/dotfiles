# sesh
function sesh-sessions() {
  {
    exec </dev/tty
    exec <&1
    local session
    session=$(sesh list -t -c -d -z | fzf --height 40% --reverse --border-label ' sesh ' --border --prompt '⚡  ')
    zle reset-prompt > /dev/null 2>&1 || true
    [[ -z "$session" ]] && return
    sesh connect $session
  }
}

alias seshl='sesh-sessions'

# Ctrl + arrow keys left/right not working
bindkey "^[[1;5C" forward-word
bindkey "^[[1;5D" backward-word

# Add Kitty to path
export PATH="$HOME/.local/bin:$PATH"

# Bitwarden SSH agent
{{- if eq .chezmoi.os "darwin" }}
export SSH_AUTH_SOCK=$HOME/Library/Containers/com.bitwarden.desktop/Data/.bitwarden-ssh-agent.sock
{{- else if eq .chezmoi.os "linux" }}
# Flatpak
export SSH_AUTH_SOCK=$HOME/.var/app/com.bitwarden.desktop/data/.bitwarden-ssh-agent.sock
export PATH="$PATH:/opt/nvim-linux-x86_64/bin"
{{- end }}

# Load ENV variables
{{- if .is_work }}
# GitHub Token
export HOMEBREW_GITHUB_API_TOKEN={{ .gh_pat }}

# Claude Code
export ANTHROPIC_DEFAULT_SONNET_MODEL="anthropic.claude-sonnet-4-5-20250929-v1:0"
