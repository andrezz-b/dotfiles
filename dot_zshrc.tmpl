# Add custom completions to fpath
fpath=(~/.local/share/zsh/completions $fpath)

# Load zinit
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

# Add zsh plugins
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light jeffreytse/zsh-vi-mode

# Load completions
autoload -U compinit && compinit

# fzf-tab should be loaded after compinit
zinit light Aloxaf/fzf-tab

# Replay cached completions for performance
zinit cdreplay -q

# History
HISTSIZE=2000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups


# Completion styling
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no

# Configure fzf-tab preview based on available tools
if command -v eza &> /dev/null; then
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --color=always $realpath'
  zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza --color=always $realpath'
else
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls -lah $realpath'
  zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls -lah $realpath'
fi

# Shell integrations
if command -v zoxide &> /dev/null; then
  eval "$(zoxide init --cmd cd zsh)"
fi

if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi

if [ "$TERM_PROGRAM" != "Apple_Terminal" ] && command -v oh-my-posh &> /dev/null; then
  eval "$(oh-my-posh init zsh --config ~/.config/oh-my-posh.toml)"
fi

# Eza - improved ls
if command -v eza &> /dev/null; then
  alias ls='eza'
  alias ll='eza -lhg'
  alias lla='eza -alhg'
  alias tree='eza --tree'
else
  alias ll='ls -lh'
  alias lla='ls -lah'
  alias tree='ls -R'
fi

# Bat - improved cat
if command -v bat &> /dev/null; then
  alias cat='bat --paging=never --style=plain'
  alias catt='bat'
  alias cata='bat --show-all --paging=never --style=plain'
  # Colored man and help pages
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
  alias -g -- --help='--help 2>&1 | bat --language=help --style=plain'
fi

# zsh-vim plugin rebinds the keys so to keep the bindings from other plugins they need to be here
zvm_after_init_commands+=(
  "bindkey '^p' history-search-backward"
  "bindkey '^n' history-search-forward"
  "bindkey '^y' autosuggest-accept"
)

# FZF integration - only if fzf is installed
if command -v fzf &> /dev/null; then
  zvm_after_init_commands+=( ". <(fzf --zsh)" )

  # Configure FZF to use fd if available, otherwise use find
  if command -v fd &> /dev/null; then
    export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git"
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"

    # Use fd (https://github.com/sharkdp/fd) for listing path candidates.
    # - The first argument to the function ($1) is the base path to start traversal
    # - See the source code (completion.{bash,zsh}) for the details.
    _fzf_compgen_path() {
      fd --hidden --exclude .git . "$1"
    }

    # Use fd to generate the list for directory completion
    _fzf_compgen_dir() {
      fd --type=d --hidden --exclude .git . "$1"
    }
  else
    export FZF_DEFAULT_COMMAND="find . -path '*/\.*' -prune -o -type f -print -o -type l -print 2> /dev/null | sed s/^..//"
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND="find . -path '*/\.*' -prune -o -type d -print 2> /dev/null | sed s/^..//"
  fi
fi

# sesh - only if sesh and fzf are installed
if command -v sesh &> /dev/null && command -v fzf &> /dev/null; then
  function sesh-sessions() {
    {
      exec </dev/tty
      exec <&1
      local session
      session=$(sesh list -t -c -d -z | fzf --height 40% --reverse --border-label ' sesh ' --border --prompt '⚡  ')
      zle reset-prompt > /dev/null 2>&1 || true
      [[ -z "$session" ]] && return
      sesh connect $session
    }
  }

  alias seshl='sesh-sessions'
fi

# Ctrl + arrow keys left/right not working
bindkey "^[[1;5C" forward-word
bindkey "^[[1;5D" backward-word

# Bitwarden login
bwlogin() {
  export BW_SESSION="$(bw unlock --raw)"
}

# Bitwarden SSH agent
{{- if eq .chezmoi.os "darwin" }}
export SSH_AUTH_SOCK=$HOME/.bitwarden-ssh-agent.sock
{{- else if eq .chezmoi.os "linux" }}
# Check for Bitwarden SSH agent socket based on installation type
if [ -S "$HOME/snap/bitwarden/current/.bitwarden-ssh-agent.sock" ]; then
  # Snap installation
  export SSH_AUTH_SOCK=$HOME/snap/bitwarden/current/.bitwarden-ssh-agent.sock
elif [ -S "$HOME/.var/app/com.bitwarden.desktop/data/.bitwarden-ssh-agent.sock" ]; then
  # Flatpak installation
  export SSH_AUTH_SOCK=$HOME/.var/app/com.bitwarden.desktop/data/.bitwarden-ssh-agent.sock
elif [ -S "$HOME/.bitwarden-ssh-agent.sock" ]; then
  # Binary installation
  export SSH_AUTH_SOCK=$HOME/.bitwarden-ssh-agent.sock
fi
{{- end }}

# Load ENV variables
{{- if .is_work }}
export PATH="$(brew --prefix)/opt/postgresql@16/bin:$PATH"

# GitHub Token
export HOMEBREW_GITHUB_API_TOKEN={{ (bitwarden "item" "Secret-GitHubPAT").login.password | quote }}
export GITHUB_TOKEN={{ (bitwarden "item" "Secret-GitHubPAT").login.password | quote }}

# Claude Code
export ANTHROPIC_DEFAULT_SONNET_MODEL="anthropic.claude-sonnet-4-6"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="anthropic.claude-haiku-4-5-20251001-v1:0"
export ANTHROPIC_DEFAULT_OPUS_MODEL="anthropic.claude-opus-4-6-v1"
export ANTHROPIC_BASE_URL="https://models.assistant.legogroup.io/claude"
export ANTHROPIC_AUTH_TOKEN={{ (bitwarden "item" "Secret-AnthropicAuthToken").login.password | quote }}
{{- else }}
# GitHub Token (for API rate limiting)
export GITHUB_TOKEN={{ (bitwarden "item" "Secret-GitHubAPIPAT").login.password | quote }}
{{- end}}

export PATH="$HOME/.antigravity/antigravity/bin:$PATH"
export PATH="$HOME/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
{{ if stat (printf "%s/.local/bin/nvim" .chezmoi.homeDir) -}}
export EDITOR=$HOME/.local/bin/nvim
{{ else if lookPath "nvim" -}}
export EDITOR=nvim
{{ else -}}
export EDITOR=vim
{{ end -}}
