{{- if eq .chezmoi.os "linux" }}

[".local/bin/sesh"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "joshmedeski/sesh" "sesh_Linux_x86_64.tar.gz" | quote }}
    executable = true
    path = "sesh"
    refreshPeriod = "168h"

